<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg"
    android:orientation="vertical"
    android:padding="14dp">

    <!-- 뒤로 버튼 + 날짜 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/btn_back"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="← 달력"
            android:textSize="10sp"
            android:textColor="#CCFFFFFF"
            android:background="@android:color/transparent"
            android:padding="0dp" />

        <TextView
            android:id="@+id/detail_date"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="end"
            android:textSize="11sp"
            android:textColor="#CCFFFFFF"
            android:text="" />
    </LinearLayout>

    <!-- 점수 + 뱃지 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="2dp">

        <TextView
            android:id="@+id/detail_score"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="36sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:text="-" />

        <TextView
            android:id="@+id/detail_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:background="@drawable/widget_badge_bg"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:text="" />
    </LinearLayout>

    <!-- 한줄 요약 -->
    <TextView
        android:id="@+id/detail_summary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textSize="11sp"
        android:textColor="#CCFFFFFF"
        android:maxLines="2"
        android:ellipsize="end"
        android:text="" />

    <!-- 카테고리 점수 4개 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp">

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="재물" android:textSize="9sp" android:textColor="#99FFFFFF" />
            <TextView android:id="@+id/score_wealth" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:textSize="14sp"
                android:textStyle="bold" android:textColor="#FFD700" android:text="-" />
        </LinearLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="애정" android:textSize="9sp" android:textColor="#99FFFFFF" />
            <TextView android:id="@+id/score_love" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:textSize="14sp"
                android:textStyle="bold" android:textColor="#FFD700" android:text="-" />
        </LinearLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="건강" android:textSize="9sp" android:textColor="#99FFFFFF" />
            <TextView android:id="@+id/score_health" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:textSize="14sp"
                android:textStyle="bold" android:textColor="#FFD700" android:text="-" />
        </LinearLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="직업" android:textSize="9sp" android:textColor="#99FFFFFF" />
            <TextView android:id="@+id/score_career" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:textSize="14sp"
                android:textStyle="bold" android:textColor="#FFD700" android:text="-" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
