<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg"
    android:orientation="vertical"
    android:padding="12dp">

    <!-- 헤더: 이전달 | 년월 | 다음달 | 오늘 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/btn_prev"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:text="‹"
            android:textSize="22sp"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:background="@android:color/transparent" />

        <TextView
            android:id="@+id/tv_month_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:text="" />

        <TextView
            android:id="@+id/btn_next"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:text="›"
            android:textSize="22sp"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:background="@android:color/transparent" />

        <TextView
            android:id="@+id/btn_today"
            android:layout_width="wrap_content"
            android:layout_height="24dp"
            android:layout_marginStart="6dp"
            android:text="오늘"
            android:textSize="11sp"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:background="@drawable/widget_badge_bg"
            android:paddingStart="8dp"
            android:paddingEnd="8dp" />
    </LinearLayout>

    <!-- 요일 헤더 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="4dp">

        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:gravity="center"
            android:text="일" android:textSize="11sp" android:textColor="#FF9999" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:gravity="center"
            android:text="월" android:textSize="11sp" android:textColor="#CCFFFFFF" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:gravity="center"
            android:text="화" android:textSize="11sp" android:textColor="#CCFFFFFF" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:gravity="center"
            android:text="수" android:textSize="11sp" android:textColor="#CCFFFFFF" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:gravity="center"
            android:text="목" android:textSize="11sp" android:textColor="#CCFFFFFF" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:gravity="center"
            android:text="금" android:textSize="11sp" android:textColor="#CCFFFFFF" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:gravity="center"
            android:text="토" android:textSize="11sp" android:textColor="#AAAAFF" />
    </LinearLayout>

    <!-- 달력 그리드 -->
    <GridView
        android:id="@+id/calendar_grid"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:numColumns="7"
        android:verticalSpacing="1dp"
        android:horizontalSpacing="1dp"
        android:rowHeight="42dp"
        android:layout_marginTop="2dp"
        android:stretchMode="columnWidth" />

</LinearLayout>
